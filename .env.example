# Base URL dùng trong mã QR (không có dấu / ở cuối)
# Dùng IP WiFi của máy tính để điện thoại cùng mạng quét được
VITE_PUBLIC_BASE_URL=http://192.168.1.9:5173

# API backend (để trống = dùng proxy /api qua Vite dev server)
VITE_API_URL=/api

# Target cho Vite proxy (chỉ dùng khi dev)
VITE_API_PROXY_TARGET=http://localhost:3002

# Zalo — SĐT Zalo shop hoặc Official Account ID
# Ví dụ: 098xxxxxxx → mở https://zalo.me/098xxxxxxx
VITE_ZALO_OA_ID=
VITE_SHOP_NAME=QOA Florist
